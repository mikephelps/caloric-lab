---
const calculators = [
  { name: "TDEE Calculator", href: "/tdee-calculator/", desc: "Total daily energy expenditure" },
  { name: "Calorie Deficit Calculator", href: "/calorie-deficit-calculator/", desc: "Plan your deficit for fat loss" },
  { name: "Macro Calculator", href: "/macro-calculator/", desc: "Protein, carbs & fat targets" },
  { name: "BMR Calculator", href: "/bmr-calculator/", desc: "Your basal metabolic rate" },
  { name: "Protein Calculator", href: "/protein-calculator/", desc: "Daily protein requirements" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 shrink-0" aria-label="CaloricLab home">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="32" height="32" rx="7" fill="#15803d"/>
          <path d="M13 10h6a1 1 0 0 1 1 1v1.5a4.5 4.5 0 0 1-4.5 4.5h-1a1 1 0 0 0-1 1V21a1 1 0 0 1-1 1h-.5a.5.5 0 0 1-.5-.5V11a1 1 0 0 1 1-1z" fill="white"/>
          <circle cx="20.5" cy="20.5" r="2.5" fill="#86efac"/>
        </svg>
        <span class="text-lg font-bold text-gray-900 tracking-tight">CaloricLab</span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-1">

        <!-- Calculators dropdown -->
        <div class="relative group">
          <button
            class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-gray-600 hover:text-green-700 rounded-lg hover:bg-green-50 transition-colors"
            aria-haspopup="true"
          >
            Calculators
            <svg class="w-3.5 h-3.5 mt-px transition-transform group-hover:rotate-180" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M4 6l4 4 4-4"/>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M3.293 5.293a1 1 0 0 1 1.414 0L8 8.586l3.293-3.293a1 1 0 1 1 1.414 1.414l-4 4a1 1 0 0 1-1.414 0l-4-4a1 1 0 0 1 0-1.414z"/>
            </svg>
          </button>

          <div class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-72 bg-white border border-gray-100 rounded-2xl shadow-xl shadow-gray-100/50 opacity-0 invisible translate-y-1 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-200">
            <div class="p-2">
              {calculators.map(c => (
                <a
                  href={c.href}
                  class:list={[
                    "flex items-start gap-3 px-3 py-2.5 rounded-xl transition-colors",
                    currentPath === c.href
                      ? "bg-green-50 text-green-700"
                      : "text-gray-700 hover:bg-gray-50"
                  ]}
                >
                  <div class="mt-0.5 flex-shrink-0 w-7 h-7 rounded-lg bg-green-100 flex items-center justify-center">
                    <svg class="w-3.5 h-3.5 text-green-700" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                      <path d="M2 3a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3zm0 6a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V9zm8 0a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1V9zm0 4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-1z"/>
                    </svg>
                  </div>
                  <div>
                    <div class="text-sm font-medium">{c.name}</div>
                    <div class="text-xs text-gray-500 mt-0.5">{c.desc}</div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>

        <a
          href="/blog/"
          class:list={[
            "px-3 py-2 text-sm font-medium rounded-lg transition-colors",
            currentPath.startsWith("/blog")
              ? "text-green-700 bg-green-50"
              : "text-gray-600 hover:text-green-700 hover:bg-green-50"
          ]}
        >
          Blog
        </a>

        <a
          href="/about/"
          class:list={[
            "px-3 py-2 text-sm font-medium rounded-lg transition-colors",
            currentPath === "/about/"
              ? "text-green-700 bg-green-50"
              : "text-gray-600 hover:text-green-700 hover:bg-green-50"
          ]}
        >
          About
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-xl text-gray-600 hover:bg-gray-100 transition-colors"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="hamburger-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="close-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-gray-100 bg-white"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">

      <!-- Mobile calculators section -->
      <div class="pb-2">
        <p class="px-3 py-1 text-xs font-semibold text-gray-400 uppercase tracking-wider">Calculators</p>
        {calculators.map(c => (
          <a
            href={c.href}
            class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-gray-700 hover:bg-green-50 hover:text-green-700 transition-colors"
          >
            {c.name}
          </a>
        ))}
      </div>

      <div class="border-t border-gray-100 pt-2 space-y-1">
        <a href="/blog/" class="block px-3 py-2.5 rounded-xl text-sm font-medium text-gray-700 hover:bg-green-50 hover:text-green-700 transition-colors">Blog</a>
        <a href="/about/" class="block px-3 py-2.5 rounded-xl text-sm font-medium text-gray-700 hover:bg-green-50 hover:text-green-700 transition-colors">About</a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const hamburger = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");

  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");

    if (isOpen) {
      menu?.classList.add("hidden");
      hamburger?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
    } else {
      menu?.classList.remove("hidden");
      hamburger?.classList.add("hidden");
      closeIcon?.classList.remove("hidden");
      btn?.setAttribute("aria-expanded", "true");
    }
  });
</script>
