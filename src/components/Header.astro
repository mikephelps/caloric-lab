---
const calculators = [
  { name: "TDEE Calculator", href: "/tdee-calculator/", desc: "Total daily energy expenditure" },
  { name: "Calorie Deficit Calculator", href: "/calorie-deficit-calculator/", desc: "Plan your deficit for fat loss" },
  { name: "Macro Calculator", href: "/macro-calculator/", desc: "Protein, carbs & fat targets" },
  { name: "BMR Calculator", href: "/bmr-calculator/", desc: "Your basal metabolic rate" },
  { name: "Protein Calculator", href: "/protein-calculator/", desc: "Daily protein requirements" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 shrink-0" aria-label="CaloricLab home">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g clip-path="url(#clip0_1_2)">
        <path d="M24 0H8C3.58172 0 0 3.58172 0 8V24C0 28.4183 3.58172 32 8 32H24C28.4183 32 32 28.4183 32 24V8C32 3.58172 28.4183 0 24 0Z" fill="url(#paint0_linear_1_2)"/>
        <path d="M10.088 10.196H12.824C12.908 10.196 12.992 10.28 12.992 10.364V10.508C12.992 12.548 11.108 14.144 9.104 14.144C7.136 14.144 5.204 12.548 5.204 10.508V7.796C5.204 5.828 7.136 4.244 9.104 4.244C11.108 4.244 12.992 5.828 12.992 7.796V8.012C12.992 8.108 12.908 8.192 12.824 8.192H10.088C9.98 8.192 9.896 8.096 9.896 8V7.94C9.896 7.724 9.752 7.46 9.572 7.352C8.924 6.98 8.312 7.436 8.312 8.012V10.388C8.312 10.796 8.66 11.156 9.104 11.156C9.524 11.156 9.896 10.796 9.896 10.388C9.896 10.28 9.98 10.196 10.088 10.196Z" fill="white"/>
        <path d="M25.952 23.76C26.396 23.76 26.756 24.156 26.756 24.6V26.208C26.756 26.64 26.396 27 25.952 27H21.188C20.672 27 20.396 26.64 20.396 26.208V18.372C20.396 17.856 20.756 17.4 21.272 17.4H22.664C23.156 17.4 23.612 17.856 23.612 18.372V23.76H25.952Z" fill="white"/>
        <path d="M7.976 22.2L5.54 18.72C5.54 18.72 5.24 18.288 5.528 17.808C5.78 17.388 6.236 17.424 6.236 17.424H7.568C7.568 17.424 7.964 17.388 8.24 17.76L9.764 19.86L11.276 17.772C11.276 17.772 11.372 17.628 11.54 17.52C11.732 17.412 11.948 17.424 11.948 17.424H13.292C13.376 17.424 13.772 17.424 14.012 17.832C14.276 18.324 13.976 18.72 13.976 18.72L11.552 22.2L13.964 25.668C13.964 25.668 14.336 26.172 13.94 26.664C13.7 26.964 13.376 26.976 13.292 26.976H11.948C11.936 26.976 11.528 27 11.264 26.616L9.764 24.528C9.764 24.528 8.288 26.568 8.252 26.628C8.012 26.94 7.724 26.964 7.568 26.976H6.236C6.236 26.976 5.756 26.988 5.504 26.544C5.252 26.112 5.516 25.716 5.54 25.692C5.552 25.668 7.976 22.2 7.976 22.2Z" fill="#04DF72"/>
        <path d="M27 10.4798C27 10.7572 26.7615 11 26.4495 11H19.5505C19.2385 11 19 10.7572 19 10.4798V8.52023C19 8.24278 19.2385 8 19.5505 8H26.4495C26.7615 8 27 8.24278 27 8.52023V10.4798Z" fill="#04DF72"/>
        </g>
        <defs>
        <linearGradient id="paint0_linear_1_2" x1="0.7018" y1="2.76609e-07" x2="31.2982" y2="32" gradientUnits="userSpaceOnUse">
        <stop stop-color="#007096"/>
        <stop offset="1" stop-color="#15803D"/>
        </linearGradient>
        <clipPath id="clip0_1_2">
        <rect width="32" height="32" fill="white"/>
        </clipPath>
        </defs>
      </svg>
        <span class="text-lg font-bold text-gray-900 tracking-tight">CaloricLab</span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-1">

        <!-- Calculators dropdown -->
        <div class="relative group">
          <button
            class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-gray-600 hover:text-green-700 rounded-lg hover:bg-green-50 transition-colors"
            aria-haspopup="true"
          >
            Calculators
            <svg class="w-3.5 h-3.5 mt-px transition-transform group-hover:rotate-180" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M4 6l4 4 4-4"/>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M3.293 5.293a1 1 0 0 1 1.414 0L8 8.586l3.293-3.293a1 1 0 1 1 1.414 1.414l-4 4a1 1 0 0 1-1.414 0l-4-4a1 1 0 0 1 0-1.414z"/>
            </svg>
          </button>

          <div class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-72 bg-white border border-gray-100 rounded-2xl shadow-xl shadow-gray-100/50 opacity-0 invisible translate-y-1 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-200">
            <div class="p-2">
              {calculators.map(c => (
                <a
                  href={c.href}
                  class:list={[
                    "flex items-start gap-3 px-3 py-2.5 rounded-xl transition-colors",
                    currentPath === c.href
                      ? "bg-green-50 text-green-700"
                      : "text-gray-700 hover:bg-gray-50"
                  ]}
                >
                  <div class="mt-0.5 flex-shrink-0 w-7 h-7 rounded-lg bg-green-100 flex items-center justify-center">
                    <svg class="w-3.5 h-3.5 text-green-700" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                      <path d="M2 3a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3zm0 6a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V9zm8 0a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1V9zm0 4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-1z"/>
                    </svg>
                  </div>
                  <div>
                    <div class="text-sm font-medium">{c.name}</div>
                    <div class="text-xs text-gray-500 mt-0.5">{c.desc}</div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>

        <a
          href="/blog/"
          class:list={[
            "px-3 py-2 text-sm font-medium rounded-lg transition-colors",
            currentPath.startsWith("/blog")
              ? "text-green-700 bg-green-50"
              : "text-gray-600 hover:text-green-700 hover:bg-green-50"
          ]}
        >
          Blog
        </a>

        <a
          href="/about/"
          class:list={[
            "px-3 py-2 text-sm font-medium rounded-lg transition-colors",
            currentPath === "/about/"
              ? "text-green-700 bg-green-50"
              : "text-gray-600 hover:text-green-700 hover:bg-green-50"
          ]}
        >
          About
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-xl text-gray-600 hover:bg-gray-100 transition-colors"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="hamburger-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="close-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-gray-100 bg-white"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">

      <!-- Mobile calculators section -->
      <div class="pb-2">
        <p class="px-3 py-1 text-xs font-semibold text-gray-400 uppercase tracking-wider">Calculators</p>
        {calculators.map(c => (
          <a
            href={c.href}
            class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-gray-700 hover:bg-green-50 hover:text-green-700 transition-colors"
          >
            {c.name}
          </a>
        ))}
      </div>

      <div class="border-t border-gray-100 pt-2 space-y-1">
        <a href="/blog/" class="block px-3 py-2.5 rounded-xl text-sm font-medium text-gray-700 hover:bg-green-50 hover:text-green-700 transition-colors">Blog</a>
        <a href="/about/" class="block px-3 py-2.5 rounded-xl text-sm font-medium text-gray-700 hover:bg-green-50 hover:text-green-700 transition-colors">About</a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const hamburger = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");

  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");

    if (isOpen) {
      menu?.classList.add("hidden");
      hamburger?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
    } else {
      menu?.classList.remove("hidden");
      hamburger?.classList.add("hidden");
      closeIcon?.classList.remove("hidden");
      btn?.setAttribute("aria-expanded", "true");
    }
  });
</script>
