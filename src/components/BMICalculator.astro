---
// Pure Astro component — zero framework JS
---

<div class="space-y-5">

  <!-- Form card -->
  <div class="bg-white rounded-2xl ring-1 ring-gray-900/[0.08] shadow-xl shadow-green-900/[0.08] overflow-hidden">
    <div class="px-6 py-4 bg-gray-950 flex items-center gap-2">
      <svg class="w-4 h-4 text-green-400" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <circle cx="8" cy="4" r="2.5"/>
        <path d="M4 14.5v-3a4 4 0 0 1 8 0v3z"/>
      </svg>
      <span class="text-sm font-bold text-white">BMI Calculator</span>
      <span class="text-sm text-green-400">· Enter Your Details</span>
    </div>

    <div class="p-6 sm:p-8 space-y-6">

      <!-- Weight -->
      <div>
        <label for="bmi-weight" class="block text-xs font-semibold text-gray-600 uppercase tracking-wider mb-2.5">Body Weight</label>
        <div class="flex gap-2">
          <input
            id="bmi-weight"
            type="number"
            inputmode="decimal"
            min="0"
            placeholder="185"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 hover:border-gray-300 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-green-500/25 focus:border-green-400 transition-colors placeholder:text-gray-300"
          />
          <div id="bmi-unit-toggle" class="inline-flex rounded-xl bg-gray-100 p-1 gap-0.5">
            <button type="button" data-wunit="lbs" class="rounded-lg font-semibold transition-all px-3 py-1.5 text-xs bg-white text-gray-900 shadow-sm border border-gray-200">lbs</button>
            <button type="button" data-wunit="kg"  class="rounded-lg font-semibold transition-all px-3 py-1.5 text-xs text-gray-500 hover:text-gray-700">kg</button>
          </div>
        </div>
        <p id="bmi-weight-err" class="mt-1.5 text-xs text-red-500 font-medium hidden">Enter a valid weight.</p>
      </div>

      <!-- Height -->
      <div>
        <div class="flex items-center justify-between mb-2.5">
          <label id="bmi-height-label" class="block text-xs font-semibold text-gray-600 uppercase tracking-wider">Height (ft / in)</label>
          <div id="bmi-height-toggle" class="inline-flex rounded-xl bg-gray-100 p-1 gap-0.5">
            <button type="button" data-hunit="imperial" class="rounded-lg font-semibold transition-all px-3 py-1.5 text-xs bg-white text-gray-900 shadow-sm border border-gray-200">ft / in</button>
            <button type="button" data-hunit="metric"   class="rounded-lg font-semibold transition-all px-3 py-1.5 text-xs text-gray-500 hover:text-gray-700">cm</button>
          </div>
        </div>

        <!-- Imperial group (shown by default) -->
        <div id="bmi-ht-imp">
          <div class="flex gap-2">
            <div class="relative w-24">
              <input id="bmi-ft" type="number" inputmode="numeric" min="1" max="8" placeholder="5" class="w-full px-4 py-3 rounded-xl border border-gray-200 hover:border-gray-300 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-green-500/25 focus:border-green-400 transition-colors placeholder:text-gray-300 pr-8"/>
              <span class="absolute right-3.5 top-1/2 -translate-y-1/2 text-xs font-semibold text-gray-500 pointer-events-none select-none">ft</span>
            </div>
            <div class="relative w-24">
              <input id="bmi-in" type="number" inputmode="numeric" min="0" max="11" placeholder="10" class="w-full px-4 py-3 rounded-xl border border-gray-200 hover:border-gray-300 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-green-500/25 focus:border-green-400 transition-colors placeholder:text-gray-300 pr-7"/>
              <span class="absolute right-3.5 top-1/2 -translate-y-1/2 text-xs font-semibold text-gray-500 pointer-events-none select-none">in</span>
            </div>
          </div>
          <p id="bmi-ft-err" class="mt-1.5 text-xs text-red-500 font-medium hidden">Enter feet (1–8).</p>
          <p id="bmi-in-err" class="mt-1.5 text-xs text-red-500 font-medium hidden">Enter inches (0–11).</p>
        </div>

        <!-- Metric group (hidden by default) -->
        <div id="bmi-ht-met" class="hidden">
          <div class="relative">
            <input id="bmi-cm" type="number" inputmode="numeric" min="50" max="300" placeholder="178" class="w-full px-4 py-3 rounded-xl border border-gray-200 hover:border-gray-300 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-green-500/25 focus:border-green-400 transition-colors placeholder:text-gray-300 pr-12"/>
            <span class="absolute right-3.5 top-1/2 -translate-y-1/2 text-xs font-semibold text-gray-500 pointer-events-none select-none">cm</span>
          </div>
          <p id="bmi-cm-err" class="mt-1.5 text-xs text-red-500 font-medium hidden">Enter height in cm (50–300).</p>
        </div>
      </div>

      <!-- Submit -->
      <div class="pt-2 border-t border-gray-100">
        <button
          id="bmi-submit"
          type="button"
          class="btn-calc w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 text-white text-sm font-bold rounded-xl shadow-md"
        >
          Calculate My BMI
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.44 8 8.22 4.78a.75.75 0 0 1 0-1.06z" clip-rule="evenodd"/>
            <path fill-rule="evenodd" d="M2.75 8a.75.75 0 0 1 .75-.75h8a.75.75 0 0 1 0 1.5h-8A.75.75 0 0 1 2.75 8z" clip-rule="evenodd"/>
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Results (injected by script) -->
  <div id="bmi-results" class="hidden"></div>

</div>

<!-- Ensure animate-fade-up is included in Tailwind output -->
<span class="animate-fade-up hidden" aria-hidden="true"></span>

<script>
  const CATEGORIES = [
    { min: 0,    max: 18.5, label: 'Underweight', textColor: 'text-blue-600',   bgColor: 'bg-blue-50',    borderColor: 'border-blue-200'   },
    { min: 18.5, max: 25,   label: 'Normal',       textColor: 'text-green-700',  bgColor: 'bg-green-50',   borderColor: 'border-green-200'  },
    { min: 25,   max: 30,   label: 'Overweight',   textColor: 'text-yellow-700', bgColor: 'bg-yellow-50',  borderColor: 'border-yellow-200' },
    { min: 30,   max: 35,   label: 'Obese I',      textColor: 'text-orange-600', bgColor: 'bg-orange-50',  borderColor: 'border-orange-200' },
    { min: 35,   max: 40,   label: 'Obese II',     textColor: 'text-red-600',    bgColor: 'bg-red-50',     borderColor: 'border-red-200'    },
    { min: 40,   max: 999,  label: 'Obese III',    textColor: 'text-red-700',    bgColor: 'bg-red-100',    borderColor: 'border-red-300'    },
  ];

  const PILL_SM_ACTIVE   = 'rounded-lg font-semibold transition-all px-3 py-1.5 text-xs bg-white text-gray-900 shadow-sm border border-gray-200';
  const PILL_SM_INACTIVE = 'rounded-lg font-semibold transition-all px-3 py-1.5 text-xs text-gray-500 hover:text-gray-700';
  const INPUT_OK    = 'w-full px-4 py-3 rounded-xl border border-gray-200 hover:border-gray-300 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-green-500/25 focus:border-green-400 transition-colors placeholder:text-gray-300';
  const INPUT_ERROR = 'w-full px-4 py-3 rounded-xl border border-red-300 bg-red-50/40 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-green-500/25 focus:border-green-400 transition-colors placeholder:text-gray-300';
  const ARROW_SVG = `<svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.44 8 8.22 4.78a.75.75 0 0 1 0-1.06z" clip-rule="evenodd"/><path fill-rule="evenodd" d="M2.75 8a.75.75 0 0 1 .75-.75h8a.75.75 0 0 1 0 1.5h-8A.75.75 0 0 1 2.75 8z" clip-rule="evenodd"/></svg>`;

  let weightUnit = 'lbs';
  let heightUnit = 'imperial';

  function setErr(inputId, errId, show, extraClass) {
    const inp = document.getElementById(inputId);
    const err = document.getElementById(errId);
    inp.className = (show ? INPUT_ERROR : INPUT_OK) + (extraClass ? ' ' + extraClass : '');
    if (err) err.classList.toggle('hidden', !show);
  }

  // ── Weight unit toggle ──────────────────────────────────────────────────────
  document.querySelectorAll('#bmi-unit-toggle [data-wunit]').forEach(btn => {
    btn.addEventListener('click', () => {
      const newUnit = btn.dataset.wunit;
      if (newUnit === weightUnit) return;
      const wInput = document.getElementById('bmi-weight');
      const val = parseFloat(wInput.value);
      if (!isNaN(val) && val > 0) {
        wInput.value = newUnit === 'kg'
          ? (val * 0.453592).toFixed(1)
          : (val * 2.20462).toFixed(1);
      }
      weightUnit = newUnit;
      wInput.placeholder = newUnit === 'lbs' ? '185' : '84';
      document.querySelectorAll('#bmi-unit-toggle [data-wunit]').forEach(b => {
        b.className = b.dataset.wunit === weightUnit ? PILL_SM_ACTIVE : PILL_SM_INACTIVE;
      });
    });
  });

  // ── Height unit toggle ──────────────────────────────────────────────────────
  document.querySelectorAll('#bmi-height-toggle [data-hunit]').forEach(btn => {
    btn.addEventListener('click', () => {
      const newUnit = btn.dataset.hunit;
      if (newUnit === heightUnit) return;
      if (newUnit === 'metric') {
        const ft = parseFloat(document.getElementById('bmi-ft').value) || 0;
        const ins = parseFloat(document.getElementById('bmi-in').value) || 0;
        const cm = (ft * 12 + ins) * 2.54;
        if (cm > 0) document.getElementById('bmi-cm').value = Math.round(cm).toString();
      } else {
        const cm = parseFloat(document.getElementById('bmi-cm').value) || 0;
        if (cm > 0) {
          const totalIn = cm / 2.54;
          document.getElementById('bmi-ft').value = Math.floor(totalIn / 12).toString();
          document.getElementById('bmi-in').value = Math.round(totalIn % 12).toString();
        }
      }
      heightUnit = newUnit;
      document.getElementById('bmi-ht-imp').classList.toggle('hidden', newUnit !== 'imperial');
      document.getElementById('bmi-ht-met').classList.toggle('hidden', newUnit !== 'metric');
      document.getElementById('bmi-height-label').textContent = newUnit === 'imperial' ? 'Height (ft / in)' : 'Height (cm)';
      document.querySelectorAll('#bmi-height-toggle [data-hunit]').forEach(b => {
        b.className = b.dataset.hunit === heightUnit ? PILL_SM_ACTIVE : PILL_SM_INACTIVE;
      });
    });
  });

  // ── Calculate ───────────────────────────────────────────────────────────────
  document.getElementById('bmi-submit').addEventListener('click', () => {
    const wInput = document.getElementById('bmi-weight');
    const ftEl   = document.getElementById('bmi-ft');
    const inEl   = document.getElementById('bmi-in');
    const cmEl   = document.getElementById('bmi-cm');

    // Reset errors
    setErr('bmi-weight', 'bmi-weight-err', false);
    setErr('bmi-ft', 'bmi-ft-err', false, 'pr-8');
    setErr('bmi-in', 'bmi-in-err', false, 'pr-7');
    setErr('bmi-cm', 'bmi-cm-err', false, 'pr-12');

    let valid = true;
    const wt = parseFloat(wInput.value);
    if (!wInput.value || isNaN(wt) || wt <= 0) {
      setErr('bmi-weight', 'bmi-weight-err', true);
      valid = false;
    }

    if (heightUnit === 'imperial') {
      const ft = parseFloat(ftEl.value);
      if (!ftEl.value || isNaN(ft) || ft < 1 || ft > 8) {
        setErr('bmi-ft', 'bmi-ft-err', true, 'pr-8');
        valid = false;
      }
      const ins = parseFloat(inEl.value) || 0;
      if (ins < 0 || ins > 11) {
        setErr('bmi-in', 'bmi-in-err', true, 'pr-7');
        valid = false;
      }
    } else {
      const cm = parseFloat(cmEl.value);
      if (!cmEl.value || isNaN(cm) || cm < 50 || cm > 300) {
        setErr('bmi-cm', 'bmi-cm-err', true, 'pr-12');
        valid = false;
      }
    }

    if (!valid) return;

    const weightKg = weightUnit === 'kg' ? wt : wt * 0.453592;
    let heightM;
    if (heightUnit === 'imperial') {
      heightM = ((parseFloat(ftEl.value) || 0) * 12 + (parseFloat(inEl.value) || 0)) * 0.0254;
    } else {
      heightM = parseFloat(cmEl.value) / 100;
    }

    const bmi = weightKg / (heightM * heightM);
    const bmiRounded = Math.round(bmi * 10) / 10;
    const cat = CATEGORIES.find(c => bmi >= c.min && bmi < c.max) || CATEGORIES[CATEGORIES.length - 1];

    const minHealthyKg  = Math.round(18.5 * heightM * heightM * 10) / 10;
    const maxHealthyKg  = Math.round(24.9 * heightM * heightM * 10) / 10;
    const minHealthyLbs = Math.round(minHealthyKg * 2.20462 * 10) / 10;
    const maxHealthyLbs = Math.round(maxHealthyKg * 2.20462 * 10) / 10;

    const categoryRows = CATEGORIES.map(c => {
      const isActive = c.label === cat.label;
      const rangeLabel = c.max === 999 ? `${c.min}+` : `${c.min}–${c.max}`;
      const rowClass = isActive
        ? `flex items-center justify-between px-5 py-3 text-sm ${c.bgColor} ring-1 ring-inset ${c.borderColor}`
        : 'flex items-center justify-between px-5 py-3 text-sm bg-gray-50';
      const textClass = isActive ? c.textColor : 'text-gray-500';
      return `
        <div class="${rowClass}">
          <span class="font-semibold ${textClass}">${c.label}</span>
          <span class="tabular-nums font-medium ${textClass}">${rangeLabel}</span>
        </div>`;
    }).join('');

    const resultsEl = document.getElementById('bmi-results');
    resultsEl.innerHTML = `
      <div class="animate-fade-up space-y-4">

        <div class="rounded-2xl bg-green-700 p-6 sm:p-8 text-white">
          <p class="text-sm font-medium text-green-200/75 mb-2 tracking-wide">Your BMI is</p>
          <div class="flex items-baseline gap-3 flex-wrap">
            <span class="text-6xl sm:text-7xl font-extrabold tracking-tight tabular-nums leading-none">${bmiRounded}</span>
            <span class="text-xs font-medium text-green-100/60 bg-white/[0.1] px-3 py-1 rounded-full self-center">${cat.label}</span>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="px-5 py-3.5 border-b ${cat.borderColor} ${cat.bgColor} flex items-center gap-2">
            <span class="text-sm font-bold ${cat.textColor}">${cat.label}</span>
            <span class="text-sm text-gray-500 font-medium">— Your current BMI classification</span>
          </div>
          <div class="divide-y divide-gray-100">
            ${categoryRows}
          </div>
        </div>

        <div class="bg-[#F9FFFF] rounded-2xl border border-green-100 p-5">
          <div class="flex gap-3">
            <div class="flex-shrink-0 mt-0.5 w-8 h-8 rounded-lg bg-green-100 flex items-center justify-center">
              <svg class="w-4 h-4 text-green-700" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13zM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm3.72 3.28a.75.75 0 0 1 0-1.06L6.44 7.5 3.72 4.78a.75.75 0 0 1 1.06-1.06l3.25 3.25a.75.75 0 0 1 0 1.06L4.78 11.28a.75.75 0 0 1-1.06 0zm4.5 0a.75.75 0 0 1 0-1.06L10.94 7.5 8.22 4.78a.75.75 0 0 1 1.06-1.06l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900">Healthy weight range for your height</p>
              <p class="text-sm text-gray-600 leading-relaxed mt-1">
                Based on a BMI of 18.5–24.9, a healthy weight for your height is
                <strong>${minHealthyLbs}–${maxHealthyLbs} lbs</strong>
                (${minHealthyKg}–${maxHealthyKg} kg).
              </p>
            </div>
          </div>
        </div>

        <div class="flex gap-3 px-5 py-4 bg-amber-50 rounded-2xl border border-amber-100">
          <svg class="w-4 h-4 text-amber-500 flex-shrink-0 mt-0.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M6.457 1.047c.659-1.234 2.427-1.234 3.086 0l6.082 11.378A1.75 1.75 0 0 1 14.082 15H1.918a1.75 1.75 0 0 1-1.543-2.575zm1.763.707a.25.25 0 0 0-.44 0L1.698 13.132a.25.25 0 0 0 .22.368h12.164a.25.25 0 0 0 .22-.368zm-.53 3.996a.75.75 0 0 1 .75.75v3a.75.75 0 0 1-1.5 0v-3a.75.75 0 0 1 .75-.75zm0 6.5a1 1 0 1 0 0-2 1 1 0 0 0 0 2z" clip-rule="evenodd"/>
          </svg>
          <p class="text-xs text-amber-700 leading-relaxed">
            BMI is a screening tool, not a diagnostic measure. It may overestimate body fat in athletes or underestimate it in older adults.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <a href="/body-fat-calculator/" class="inline-flex items-center justify-center gap-2 px-5 py-3.5 bg-green-700 hover:bg-green-800 text-white text-sm font-semibold rounded-xl transition-colors">
            Calculate your body fat % ${ARROW_SVG}
          </a>
          <a href="/ideal-weight-calculator/" class="inline-flex items-center justify-center gap-2 px-5 py-3.5 bg-white hover:bg-green-50 text-green-700 text-sm font-semibold rounded-xl border border-green-200 hover:border-green-300 transition-colors">
            Find your ideal weight ${ARROW_SVG}
          </a>
        </div>

      </div>`;

    resultsEl.classList.remove('hidden');
    setTimeout(() => {
      const top = resultsEl.getBoundingClientRect().top + window.scrollY - 88;
      window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
    }, 80);
  });
</script>
