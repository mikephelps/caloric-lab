---
const calculators = [
  { name: "TDEE Calculator", href: "/tdee-calculator/" },
  { name: "Calorie Deficit Calculator", href: "/calorie-deficit-calculator/" },
  { name: "Macro Calculator", href: "/macro-calculator/" },
  { name: "BMR Calculator", href: "/bmr-calculator/" },
  { name: "Protein Calculator", href: "/protein-calculator/" },
];

const year = new Date().getFullYear();
---

<footer class="bg-gray-950 text-gray-400">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Main footer grid -->
    <div class="py-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 group" aria-label="CaloricLab home">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="32" height="32" rx="7" fill="#16a34a"/>
            <path d="M13 10h6a1 1 0 0 1 1 1v1.5a4.5 4.5 0 0 1-4.5 4.5h-1a1 1 0 0 0-1 1V21a1 1 0 0 1-1 1h-.5a.5.5 0 0 1-.5-.5V11a1 1 0 0 1 1-1z" fill="white"/>
            <circle cx="20.5" cy="20.5" r="2.5" fill="#86efac"/>
          </svg>
          <span class="text-lg font-bold text-white tracking-tight group-hover:text-green-400 transition-colors">CaloricLab</span>
        </a>
        <p class="mt-4 text-sm text-gray-500 leading-relaxed max-w-xs">
          Free, science-backed nutrition calculators to help you understand your body and reach your health goals.
        </p>
      </div>

      <!-- Calculators column -->
      <div>
        <h3 class="text-xs font-semibold text-gray-300 uppercase tracking-wider mb-4">Calculators</h3>
        <ul class="space-y-2.5">
          {calculators.map(c => (
            <li>
              <a href={c.href} class="text-sm text-gray-500 hover:text-green-400 transition-colors">
                {c.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources column -->
      <div>
        <h3 class="text-xs font-semibold text-gray-300 uppercase tracking-wider mb-4">Resources</h3>
        <ul class="space-y-2.5">
          <li><a href="/blog/" class="text-sm text-gray-500 hover:text-green-400 transition-colors">Blog</a></li>
          <li><a href="/about/" class="text-sm text-gray-500 hover:text-green-400 transition-colors">About</a></li>
        </ul>
      </div>

      <!-- Legal column -->
      <div>
        <h3 class="text-xs font-semibold text-gray-300 uppercase tracking-wider mb-4">Legal</h3>
        <ul class="space-y-2.5">
          <li><a href="/privacy/" class="text-sm text-gray-500 hover:text-green-400 transition-colors">Privacy Policy</a></li>
          <li><a href="/terms/" class="text-sm text-gray-500 hover:text-green-400 transition-colors">Terms of Use</a></li>
          <li>
            <a href="mailto:hello@caloriclab.com" class="text-sm text-gray-500 hover:text-green-400 transition-colors">Contact</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800/50 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-600 text-center sm:text-left">
        © {year} CaloricLab. All rights reserved. Results are for informational purposes only.
      </p>
      <p class="text-xs text-gray-700">
        Not medical advice. Consult a healthcare professional.
      </p>
    </div>
  </div>
</footer>
