---
const calculators = [
  { name: "TDEE Calculator", href: "/tdee-calculator/" },
  { name: "Calorie Deficit Calculator", href: "/calorie-deficit-calculator/" },
  { name: "Macro Calculator", href: "/macro-calculator/" },
  { name: "BMR Calculator", href: "/bmr-calculator/" },
  { name: "Protein Calculator", href: "/protein-calculator/" },
];

const year = new Date().getFullYear();
---

<footer class="bg-gray-950 text-gray-400">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Main footer grid -->
    <div class="py-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 group" aria-label="CaloricLab home">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <g clip-path="url(#footer_clip)">
            <path d="M24 0H8C3.58172 0 0 3.58172 0 8V24C0 28.4183 3.58172 32 8 32H24C28.4183 32 32 28.4183 32 24V8C32 3.58172 28.4183 0 24 0Z" fill="url(#footer_gradient)"/>
            <path d="M10.088 10.196H12.824C12.908 10.196 12.992 10.28 12.992 10.364V10.508C12.992 12.548 11.108 14.144 9.104 14.144C7.136 14.144 5.204 12.548 5.204 10.508V7.796C5.204 5.828 7.136 4.244 9.104 4.244C11.108 4.244 12.992 5.828 12.992 7.796V8.012C12.992 8.108 12.908 8.192 12.824 8.192H10.088C9.98 8.192 9.896 8.096 9.896 8V7.94C9.896 7.724 9.752 7.46 9.572 7.352C8.924 6.98 8.312 7.436 8.312 8.012V10.388C8.312 10.796 8.66 11.156 9.104 11.156C9.524 11.156 9.896 10.796 9.896 10.388C9.896 10.28 9.98 10.196 10.088 10.196Z" fill="white"/>
            <path d="M25.952 23.76C26.396 23.76 26.756 24.156 26.756 24.6V26.208C26.756 26.64 26.396 27 25.952 27H21.188C20.672 27 20.396 26.64 20.396 26.208V18.372C20.396 17.856 20.756 17.4 21.272 17.4H22.664C23.156 17.4 23.612 17.856 23.612 18.372V23.76H25.952Z" fill="white"/>
            <path d="M7.976 22.2L5.54 18.72C5.54 18.72 5.24 18.288 5.528 17.808C5.78 17.388 6.236 17.424 6.236 17.424H7.568C7.568 17.424 7.964 17.388 8.24 17.76L9.764 19.86L11.276 17.772C11.276 17.772 11.372 17.628 11.54 17.52C11.732 17.412 11.948 17.424 11.948 17.424H13.292C13.376 17.424 13.772 17.424 14.012 17.832C14.276 18.324 13.976 18.72 13.976 18.72L11.552 22.2L13.964 25.668C13.964 25.668 14.336 26.172 13.94 26.664C13.7 26.964 13.376 26.976 13.292 26.976H11.948C11.936 26.976 11.528 27 11.264 26.616L9.764 24.528C9.764 24.528 8.288 26.568 8.252 26.628C8.012 26.94 7.724 26.964 7.568 26.976H6.236C6.236 26.976 5.756 26.988 5.504 26.544C5.252 26.112 5.516 25.716 5.54 25.692C5.552 25.668 7.976 22.2 7.976 22.2Z" fill="#04DF72"/>
            <path d="M27 10.4798C27 10.7572 26.7615 11 26.4495 11H19.5505C19.2385 11 19 10.7572 19 10.4798V8.52023C19 8.24278 19.2385 8 19.5505 8H26.4495C26.7615 8 27 8.24278 27 8.52023V10.4798Z" fill="#04DF72"/>
            </g>
            <defs>
            <linearGradient id="footer_gradient" x1="0.7018" y1="2.76609e-07" x2="31.2982" y2="32" gradientUnits="userSpaceOnUse">
              <stop stop-color="#007096"/>
              <stop offset="1" stop-color="#15803D"/>
            </linearGradient>
            <clipPath id="footer_clip">
              <rect width="32" height="32" fill="white"/>
            </clipPath>
            </defs>
          </svg>
          <span class="text-lg font-bold text-white tracking-tight group-hover:text-green-400 transition-colors">CaloricLab</span>
        </a>
        <p class="mt-4 text-sm text-gray-500 leading-relaxed max-w-xs">
          Free, science-backed nutrition calculators to help you understand your body and reach your health goals.
        </p>
      </div>

      <!-- Calculators column -->
      <div>
        <h3 class="text-xs font-semibold text-gray-300 uppercase tracking-wider mb-4">Calculators</h3>
        <ul class="space-y-2.5">
          {calculators.map(c => (
            <li>
              <a href={c.href} class="text-sm text-gray-500 hover:text-green-400 transition-colors">
                {c.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources column -->
      <div>
        <h3 class="text-xs font-semibold text-gray-300 uppercase tracking-wider mb-4">Resources</h3>
        <ul class="space-y-2.5">
          <li><a href="/blog/" class="text-sm text-gray-500 hover:text-green-400 transition-colors">Blog</a></li>
          <li><a href="/about/" class="text-sm text-gray-500 hover:text-green-400 transition-colors">About</a></li>
        </ul>
      </div>

      <!-- Legal column -->
      <div>
        <h3 class="text-xs font-semibold text-gray-300 uppercase tracking-wider mb-4">Legal</h3>
        <ul class="space-y-2.5">
          <li><a href="/privacy/" class="text-sm text-gray-500 hover:text-green-400 transition-colors">Privacy Policy</a></li>
          <li><a href="/terms/" class="text-sm text-gray-500 hover:text-green-400 transition-colors">Terms of Use</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800/50 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-600 text-center sm:text-left">
        © {year} CaloricLab. All rights reserved. Results are for informational purposes only.
      </p>
      <p class="text-xs text-gray-700">
        Not medical advice. Consult a healthcare professional.
      </p>
    </div>
  </div>
</footer>
