---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<div class="relative overflow-hidden bg-[#071e1a]">
  <!-- Blurred orbs — create the organic depth behind the glass -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-32 -right-24 w-[520px] h-[520px] rounded-full bg-green-500/30 blur-[130px]"></div>
    <div class="absolute -bottom-20 -left-20 w-[440px] h-[440px] rounded-full bg-teal-500/25 blur-[110px]"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] rounded-full bg-emerald-400/25 blur-[80px]"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-7">
    <slot name="above" />
    <h1 class="text-xl sm:text-2xl font-bold text-white tracking-tight">{title}</h1>
    {subtitle && (
      <p class="mt-2 text-sm text-white/60 max-w-2xl leading-relaxed">{subtitle}</p>
    )}
    <slot name="below" />
  </div>
</div>
