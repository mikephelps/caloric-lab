---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<div class="bg-[#F9FFFF]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-7">
    <slot name="above" />
    <h1 class="text-xl sm:text-2xl font-bold text-gray-900 tracking-tight">{title}</h1>
    {subtitle && (
      <p class="mt-2 text-sm text-gray-500 max-w-2xl leading-relaxed">{subtitle}</p>
    )}
    <slot name="below" />
  </div>
</div>
