---
// BodyFatCalculator.astro — zero React, vanilla JS
---

<div class="space-y-5">

  <!-- Form card -->
  <div class="bg-white rounded-2xl ring-1 ring-gray-900/[0.08] shadow-xl shadow-green-900/[0.08] overflow-hidden">
    <div class="px-6 py-4 bg-gray-950 flex items-center gap-2">
      <svg class="w-4 h-4 text-green-400" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <rect x="1" y="7" width="14" height="2" rx="1"/>
        <rect x="2.5" y="5" width="1.5" height="2" rx="0.5"/>
        <rect x="5.5" y="5.5" width="1.5" height="1.5" rx="0.5"/>
        <rect x="8.5" y="5" width="1.5" height="2" rx="0.5"/>
        <rect x="11.5" y="5.5" width="1.5" height="1.5" rx="0.5"/>
      </svg>
      <span class="text-sm font-bold text-white">Body Fat Calculator</span>
      <span class="text-sm text-green-400">· Enter Your Measurements</span>
    </div>

    <div class="p-6 sm:p-8 space-y-6">

      <!-- Sex -->
      <div>
        <p class="text-xs font-semibold text-gray-600 uppercase tracking-wider mb-2.5">Sex</p>
        <div class="grid grid-cols-2 gap-2.5" id="bfc-sex-group">
          <button type="button" data-sex="male" class="flex flex-col items-start gap-0.5 px-4 py-3 rounded-xl border text-left transition-all cursor-pointer w-full border-green-400 bg-green-50 ring-1 ring-green-400/30">
            <span class="text-sm font-bold text-green-700">Male</span>
            <span class="text-xs text-green-700">Waist + neck</span>
          </button>
          <button type="button" data-sex="female" class="flex flex-col items-start gap-0.5 px-4 py-3 rounded-xl border text-left transition-all cursor-pointer w-full border-gray-200 bg-white hover:border-gray-300">
            <span class="text-sm font-bold text-gray-700">Female</span>
            <span class="text-xs text-gray-500">Waist + hip + neck</span>
          </button>
        </div>
      </div>

      <!-- Measurement units -->
      <div>
        <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wider mb-2.5">Measurement Units</label>
        <div id="bfc-munit-toggle" class="inline-flex rounded-xl bg-gray-100 p-1 gap-0.5">
          <button type="button" data-munit="imperial" class="rounded-lg font-semibold transition-all px-3 py-1.5 text-xs bg-white text-gray-900 shadow-sm border border-gray-200">in</button>
          <button type="button" data-munit="metric" class="rounded-lg font-semibold transition-all px-3 py-1.5 text-xs text-gray-500 hover:text-gray-700">cm</button>
        </div>
      </div>

      <!-- Body Weight -->
      <div>
        <label for="bfc-weight" class="block text-xs font-semibold text-gray-600 uppercase tracking-wider mb-2.5">Body Weight</label>
        <div class="flex gap-2">
          <input
            id="bfc-weight"
            type="number"
            inputmode="decimal"
            min="0"
            placeholder="185"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 hover:border-gray-300 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-green-500/25 focus:border-green-400 transition-colors placeholder:text-gray-300"
          />
          <div id="bfc-wunit-toggle" class="inline-flex rounded-xl bg-gray-100 p-1 gap-0.5">
            <button type="button" data-wunit="lbs" class="rounded-lg font-semibold transition-all px-3 py-1.5 text-xs bg-white text-gray-900 shadow-sm border border-gray-200">lbs</button>
            <button type="button" data-wunit="kg" class="rounded-lg font-semibold transition-all px-3 py-1.5 text-xs text-gray-500 hover:text-gray-700">kg</button>
          </div>
        </div>
        <p id="bfc-weight-err" class="mt-1.5 text-xs text-red-500 font-medium hidden">Enter a valid weight.</p>
      </div>

      <!-- Height -->
      <div>
        <label for="bfc-height" class="block text-xs font-semibold text-gray-600 uppercase tracking-wider mb-2.5">Height</label>
        <div class="relative">
          <input
            id="bfc-height"
            type="number"
            inputmode="decimal"
            min="0"
            placeholder="70"
            class="w-full px-4 py-3 pr-10 rounded-xl border border-gray-200 hover:border-gray-300 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-green-500/25 focus:border-green-400 transition-colors placeholder:text-gray-300"
          />
          <span id="bfc-height-suffix" class="absolute right-3.5 top-1/2 -translate-y-1/2 text-xs font-semibold text-gray-500 pointer-events-none select-none">in</span>
        </div>
        <p id="bfc-height-err" class="mt-1.5 text-xs text-red-500 font-medium hidden">Enter a valid height.</p>
      </div>

      <!-- Waist -->
      <div>
        <label for="bfc-waist" class="block text-xs font-semibold text-gray-600 uppercase tracking-wider mb-2.5">Waist (at navel)</label>
        <div class="relative">
          <input
            id="bfc-waist"
            type="number"
            inputmode="decimal"
            min="0"
            placeholder="34"
            class="w-full px-4 py-3 pr-10 rounded-xl border border-gray-200 hover:border-gray-300 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-green-500/25 focus:border-green-400 transition-colors placeholder:text-gray-300"
          />
          <span id="bfc-waist-suffix" class="absolute right-3.5 top-1/2 -translate-y-1/2 text-xs font-semibold text-gray-500 pointer-events-none select-none">in</span>
        </div>
        <p id="bfc-waist-err" class="mt-1.5 text-xs text-red-500 font-medium hidden">Enter a valid waist measurement.</p>
      </div>

      <!-- Neck -->
      <div>
        <label for="bfc-neck" class="block text-xs font-semibold text-gray-600 uppercase tracking-wider mb-2.5">Neck (widest point)</label>
        <div class="relative">
          <input
            id="bfc-neck"
            type="number"
            inputmode="decimal"
            min="0"
            placeholder="15"
            class="w-full px-4 py-3 pr-10 rounded-xl border border-gray-200 hover:border-gray-300 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-green-500/25 focus:border-green-400 transition-colors placeholder:text-gray-300"
          />
          <span id="bfc-neck-suffix" class="absolute right-3.5 top-1/2 -translate-y-1/2 text-xs font-semibold text-gray-500 pointer-events-none select-none">in</span>
        </div>
        <p id="bfc-neck-err" class="mt-1.5 text-xs text-red-500 font-medium hidden">Enter a valid neck measurement.</p>
      </div>

      <!-- Hip (female only) -->
      <div id="bfc-hip-section" class="hidden">
        <label for="bfc-hip" class="block text-xs font-semibold text-gray-600 uppercase tracking-wider mb-2.5">Hip (widest point)</label>
        <div class="relative">
          <input
            id="bfc-hip"
            type="number"
            inputmode="decimal"
            min="0"
            placeholder="39"
            class="w-full px-4 py-3 pr-10 rounded-xl border border-gray-200 hover:border-gray-300 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-green-500/25 focus:border-green-400 transition-colors placeholder:text-gray-300"
          />
          <span id="bfc-hip-suffix" class="absolute right-3.5 top-1/2 -translate-y-1/2 text-xs font-semibold text-gray-500 pointer-events-none select-none">in</span>
        </div>
        <p id="bfc-hip-err" class="mt-1.5 text-xs text-red-500 font-medium hidden">Enter a valid hip measurement.</p>
      </div>

      <p class="text-xs text-gray-500 leading-relaxed -mt-2">
        Measure waist at the widest point, neck below the Adam's apple.
      </p>

      <!-- Submit -->
      <div class="pt-2 border-t border-gray-100">
        <button
          id="bfc-submit"
          type="button"
          class="btn-calc w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 text-white text-sm font-bold rounded-xl shadow-md"
        >
          Calculate Body Fat %
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.44 8 8.22 4.78a.75.75 0 0 1 0-1.06z" clip-rule="evenodd"/>
            <path fill-rule="evenodd" d="M2.75 8a.75.75 0 0 1 .75-.75h8a.75.75 0 0 1 0 1.5h-8A.75.75 0 0 1 2.75 8z" clip-rule="evenodd"/>
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Results -->
  <div id="bfc-results" class="hidden"></div>

  <span class="animate-fade-up hidden" aria-hidden="true"></span>
</div>

<script>
  const PILL_SM_ACTIVE   = 'rounded-lg font-semibold transition-all px-3 py-1.5 text-xs bg-white text-gray-900 shadow-sm border border-gray-200';
  const PILL_SM_INACTIVE = 'rounded-lg font-semibold transition-all px-3 py-1.5 text-xs text-gray-500 hover:text-gray-700';
  const CARD_ACTIVE   = 'flex flex-col items-start gap-0.5 px-4 py-3 rounded-xl border text-left transition-all cursor-pointer w-full border-green-400 bg-green-50 ring-1 ring-green-400/30';
  const CARD_INACTIVE = 'flex flex-col items-start gap-0.5 px-4 py-3 rounded-xl border text-left transition-all cursor-pointer w-full border-gray-200 bg-white hover:border-gray-300';
  const INPUT_OK    = 'w-full px-4 py-3 rounded-xl border border-gray-200 hover:border-gray-300 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-green-500/25 focus:border-green-400 transition-colors placeholder:text-gray-300';
  const INPUT_ERROR = 'w-full px-4 py-3 rounded-xl border border-red-300 bg-red-50/40 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-green-500/25 focus:border-green-400 transition-colors placeholder:text-gray-300';

  const CATEGORIES_MALE = [
    { min: 0,   max: 6,   label: 'Essential Fat', textColor: 'text-blue-700',   bgColor: 'bg-blue-50'   },
    { min: 6,   max: 14,  label: 'Athletes',       textColor: 'text-green-700',  bgColor: 'bg-green-50'  },
    { min: 14,  max: 18,  label: 'Fitness',         textColor: 'text-teal-700',   bgColor: 'bg-teal-50'   },
    { min: 18,  max: 25,  label: 'Average',         textColor: 'text-yellow-700', bgColor: 'bg-yellow-50' },
    { min: 25,  max: 999, label: 'Obese',           textColor: 'text-red-600',    bgColor: 'bg-red-50'    },
  ];
  const CATEGORIES_FEMALE = [
    { min: 0,   max: 14,  label: 'Essential Fat', textColor: 'text-blue-700',   bgColor: 'bg-blue-50'   },
    { min: 14,  max: 21,  label: 'Athletes',       textColor: 'text-green-700',  bgColor: 'bg-green-50'  },
    { min: 21,  max: 25,  label: 'Fitness',         textColor: 'text-teal-700',   bgColor: 'bg-teal-50'   },
    { min: 25,  max: 32,  label: 'Average',         textColor: 'text-yellow-700', bgColor: 'bg-yellow-50' },
    { min: 32,  max: 999, label: 'Obese',           textColor: 'text-red-600',    bgColor: 'bg-red-50'    },
  ];

  const ARROW_SVG = `<svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.44 8 8.22 4.78a.75.75 0 0 1 0-1.06z" clip-rule="evenodd"/><path fill-rule="evenodd" d="M2.75 8a.75.75 0 0 1 .75-.75h8a.75.75 0 0 1 0 1.5h-8A.75.75 0 0 1 2.75 8z" clip-rule="evenodd"/></svg>`;

  let sex        = 'male';
  let measureUnit = 'imperial';
  let weightUnit  = 'lbs';

  // helpers
  function setInputErr(id, show) {
    const el = document.getElementById(id);
    if (el) el.className = (show ? INPUT_ERROR : INPUT_OK) + ' pr-10';
  }
  function setErr(errId, show) {
    const el = document.getElementById(errId);
    if (el) el.classList.toggle('hidden', !show);
  }

  // sex toggle
  document.querySelectorAll('#bfc-sex-group [data-sex]').forEach(btn => {
    btn.addEventListener('click', () => {
      sex = btn.dataset.sex;
      document.querySelectorAll('#bfc-sex-group [data-sex]').forEach(b => {
        const active = b.dataset.sex === sex;
        b.className = active ? CARD_ACTIVE : CARD_INACTIVE;
        const spans = b.querySelectorAll('span');
        if (spans[0]) spans[0].className = `text-sm font-bold ${active ? 'text-green-700' : 'text-gray-700'}`;
        if (spans[1]) spans[1].className = `text-xs ${active ? 'text-green-700' : 'text-gray-500'}`;
      });
      document.getElementById('bfc-hip-section').classList.toggle('hidden', sex !== 'female');
    });
  });

  // measurement unit toggle
  document.querySelectorAll('#bfc-munit-toggle [data-munit]').forEach(btn => {
    btn.addEventListener('click', () => {
      measureUnit = btn.dataset.munit;
      document.querySelectorAll('#bfc-munit-toggle [data-munit]').forEach(b => {
        b.className = b.dataset.munit === measureUnit ? PILL_SM_ACTIVE : PILL_SM_INACTIVE;
      });
      const suffix = measureUnit === 'imperial' ? 'in' : 'cm';
      ['bfc-height-suffix','bfc-waist-suffix','bfc-neck-suffix','bfc-hip-suffix'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = suffix;
      });
      const hEl = document.getElementById('bfc-height');
      const wEl = document.getElementById('bfc-waist');
      const nEl = document.getElementById('bfc-neck');
      const hipEl = document.getElementById('bfc-hip');
      if (measureUnit === 'imperial') {
        hEl.placeholder = '70'; wEl.placeholder = '34'; nEl.placeholder = '15'; hipEl.placeholder = '39';
      } else {
        hEl.placeholder = '178'; wEl.placeholder = '86'; nEl.placeholder = '38'; hipEl.placeholder = '99';
      }
    });
  });

  // weight unit toggle
  document.querySelectorAll('#bfc-wunit-toggle [data-wunit]').forEach(btn => {
    btn.addEventListener('click', () => {
      const newUnit = btn.dataset.wunit;
      if (newUnit === weightUnit) return;
      const inp = document.getElementById('bfc-weight');
      const val = parseFloat(inp.value);
      if (!isNaN(val) && val > 0) {
        inp.value = newUnit === 'kg' ? (val * 0.453592).toFixed(1) : (val * 2.20462).toFixed(1);
      }
      inp.placeholder = newUnit === 'lbs' ? '185' : '84';
      weightUnit = newUnit;
      document.querySelectorAll('#bfc-wunit-toggle [data-wunit]').forEach(b => {
        b.className = b.dataset.wunit === weightUnit ? PILL_SM_ACTIVE : PILL_SM_INACTIVE;
      });
    });
  });

  // calculate
  document.getElementById('bfc-submit').addEventListener('click', () => {
    let ok = true;

    const wtN = parseFloat(document.getElementById('bfc-weight').value);
    const wtErr = !document.getElementById('bfc-weight').value || isNaN(wtN) || wtN <= 0;
    document.getElementById('bfc-weight').className = (wtErr ? INPUT_ERROR : INPUT_OK);
    setErr('bfc-weight-err', wtErr);
    if (wtErr) ok = false;

    const htN = parseFloat(document.getElementById('bfc-height').value);
    const htCm = measureUnit === 'imperial' ? htN * 2.54 : htN;
    const htErr = !document.getElementById('bfc-height').value || isNaN(htN) || htCm <= 50 || htCm >= 300;
    setInputErr('bfc-height', htErr);
    setErr('bfc-height-err', htErr);
    if (htErr) ok = false;

    const waistN = parseFloat(document.getElementById('bfc-waist').value);
    const waistErr = !document.getElementById('bfc-waist').value || isNaN(waistN) || waistN <= 0;
    setInputErr('bfc-waist', waistErr);
    if (waistErr) { setErr('bfc-waist-err', true); ok = false; }
    else setErr('bfc-waist-err', false);

    const neckN = parseFloat(document.getElementById('bfc-neck').value);
    const neckErr = !document.getElementById('bfc-neck').value || isNaN(neckN) || neckN <= 0;
    setInputErr('bfc-neck', neckErr);
    setErr('bfc-neck-err', neckErr);
    if (neckErr) ok = false;

    let hipN = 0;
    if (sex === 'female') {
      hipN = parseFloat(document.getElementById('bfc-hip').value);
      const hipErr = !document.getElementById('bfc-hip').value || isNaN(hipN) || hipN <= 0;
      setInputErr('bfc-hip', hipErr);
      setErr('bfc-hip-err', hipErr);
      if (hipErr) ok = false;
    }

    // cross-field waist > neck check
    if (ok) {
      if (sex === 'male' && waistN <= neckN) {
        setInputErr('bfc-waist', true);
        document.getElementById('bfc-waist-err').textContent = 'Waist must be larger than neck for this formula.';
        setErr('bfc-waist-err', true);
        ok = false;
      } else if (sex === 'female' && (waistN + hipN) <= neckN) {
        setInputErr('bfc-waist', true);
        document.getElementById('bfc-waist-err').textContent = 'Waist measurement appears too small relative to neck and hip.';
        setErr('bfc-waist-err', true);
        ok = false;
      }
    }

    if (!ok) return;

    const toCm = v => measureUnit === 'imperial' ? v * 2.54 : v;
    const waistCm  = toCm(waistN);
    const neckCm   = toCm(neckN);
    const heightCm = toCm(htN);

    let bodyFatPct;
    if (sex === 'male') {
      bodyFatPct = 495 / (1.0324 - 0.19077 * Math.log10(waistCm - neckCm) + 0.15456 * Math.log10(heightCm)) - 450;
    } else {
      const hipCm = toCm(hipN);
      bodyFatPct = 495 / (1.29579 - 0.35004 * Math.log10(waistCm + hipCm - neckCm) + 0.22100 * Math.log10(heightCm)) - 450;
    }
    bodyFatPct = Math.min(65, Math.max(1, bodyFatPct));
    bodyFatPct = Math.round(bodyFatPct * 10) / 10;

    const weightKg = weightUnit === 'lbs' ? wtN * 0.453592 : wtN;
    const fatMassKg  = Math.round((bodyFatPct / 100) * weightKg * 10) / 10;
    const leanMassKg = Math.round((weightKg - fatMassKg) * 10) / 10;
    const fatMassLbs  = Math.round(fatMassKg  * 2.20462 * 10) / 10;
    const leanMassLbs = Math.round(leanMassKg * 2.20462 * 10) / 10;

    const categories = sex === 'male' ? CATEGORIES_MALE : CATEGORIES_FEMALE;
    const category = categories.find(c => bodyFatPct >= c.min && bodyFatPct < c.max) ?? categories[categories.length - 1];

    const fatDisplay  = weightUnit === 'lbs' ? `${fatMassLbs} lbs`  : `${fatMassKg} kg`;
    const leanDisplay = weightUnit === 'lbs' ? `${leanMassLbs} lbs` : `${leanMassKg} kg`;
    const fatNum  = weightUnit === 'lbs' ? fatMassLbs  : fatMassKg;
    const leanNum = weightUnit === 'lbs' ? leanMassLbs : leanMassKg;
    const unit    = weightUnit;

    const categoryRows = categories.map(cat => {
      const isActive = cat.label === category.label;
      const rangeLabel = cat.max === 999 ? `${cat.min}%+` : `${cat.min}–${cat.max}%`;
      return `<div class="flex items-center justify-between px-3 py-2 rounded-lg text-xs font-medium transition-all ${isActive ? `${cat.bgColor} ${cat.textColor} ring-1 ring-current/20` : 'text-gray-500'}">
        <span>${cat.label}</span>
        <span class="tabular-nums">${rangeLabel}</span>
      </div>`;
    }).join('');

    const resultsEl = document.getElementById('bfc-results');
    resultsEl.innerHTML = `
      <div class="animate-fade-up space-y-4">

        <div class="rounded-2xl bg-green-700 p-6 sm:p-8 text-white">
          <p class="text-sm font-medium text-green-200/75 mb-2 tracking-wide">Your body fat percentage</p>
          <div class="flex items-baseline gap-3 flex-wrap">
            <span class="text-6xl sm:text-7xl font-extrabold tracking-tight tabular-nums leading-none">${bodyFatPct}</span>
            <span class="text-xl font-semibold text-green-300">% body fat</span>
          </div>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="text-xs font-medium text-green-100/60 bg-white/[0.1] px-3 py-1 rounded-full">Fat mass: ${fatDisplay}</span>
            <span class="text-xs font-medium text-green-100/60 bg-white/[0.1] px-3 py-1 rounded-full">Lean mass: ${leanDisplay}</span>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 text-center">
            <p class="text-2xl font-extrabold text-gray-900 tabular-nums leading-none">${fatNum}<span class="text-sm font-semibold text-gray-500 ml-1">${unit}</span></p>
            <p class="text-xs text-gray-500 mt-1.5 font-medium">Fat mass</p>
          </div>
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 text-center">
            <p class="text-2xl font-extrabold text-gray-900 tabular-nums leading-none">${leanNum}<span class="text-sm font-semibold text-gray-500 ml-1">${unit}</span></p>
            <p class="text-xs text-gray-500 mt-1.5 font-medium">Lean mass</p>
          </div>
        </div>

        <div class="bg-[#F9FFFF] rounded-2xl border border-green-100 p-5">
          <div class="flex gap-3">
            <div class="flex-shrink-0 mt-0.5 w-8 h-8 rounded-lg bg-green-100 flex items-center justify-center">
              <svg class="w-4 h-4 text-green-700" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13zM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-2.75a.75.75 0 0 1 .75.75v4.5a.75.75 0 0 1-1.5 0V6a.75.75 0 0 1 .75-.75zm0-2.25a1 1 0 1 0 0 2 1 1 0 0 0 0-2z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-sm font-semibold text-gray-900">Your category: <span class="${category.textColor}">${category.label}</span></p>
              <div class="mt-3 space-y-1.5">${categoryRows}</div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <a href="/bmi-calculator/" class="inline-flex items-center justify-center gap-2 px-5 py-3.5 bg-green-700 hover:bg-green-800 text-white text-sm font-semibold rounded-xl transition-colors">Calculate your BMI ${ARROW_SVG}</a>
          <a href="/ideal-weight-calculator/" class="inline-flex items-center justify-center gap-2 px-5 py-3.5 bg-white hover:bg-green-50 text-green-700 text-sm font-semibold rounded-xl border border-green-200 hover:border-green-300 transition-colors">Find your ideal weight ${ARROW_SVG}</a>
        </div>

      </div>`;
    resultsEl.classList.remove('hidden');
    setTimeout(() => {
      const top = resultsEl.getBoundingClientRect().top + window.scrollY - 88;
      window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
    }, 80);
  });
</script>
