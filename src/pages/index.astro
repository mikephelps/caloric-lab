---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const recentPosts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}

const calculators = [
  {
    name: "TDEE Calculator",
    href: "/tdee-calculator/",
    desc: "Find out exactly how many calories your body burns each day based on your activity level.",
    icon: "flame",
    tag: "Most Popular",
  },
  {
    name: "Calorie Deficit Calculator",
    href: "/calorie-deficit-calculator/",
    desc: "Calculate the precise calorie deficit you need to lose weight at your desired pace.",
    icon: "trending-down",
    tag: null,
  },
  {
    name: "Macro Calculator",
    href: "/macro-calculator/",
    desc: "Get personalized protein, carbohydrate, and fat targets tailored to your goals.",
    icon: "chart-pie",
    tag: null,
  },
  {
    name: "BMR Calculator",
    href: "/bmr-calculator/",
    desc: "Calculate your basal metabolic rate — the calories your body burns at complete rest.",
    icon: "heart-pulse",
    tag: null,
  },
  {
    name: "Protein Calculator",
    href: "/protein-calculator/",
    desc: "Determine your optimal daily protein intake to build muscle or maintain lean mass.",
    icon: "dumbbell",
    tag: null,
  },
];

const calcIcons: Record<string, string> = {
  "flame": `<path d="M8 2c-1 2-4 4.5-4 7a4 4 0 0 0 8 0C12 6.5 9 4 8 2z"/>`,
  "trending-down": `<rect x="1.5" y="3" width="3" height="10" rx="1"/><rect x="6.5" y="5.5" width="3" height="7.5" rx="1"/><rect x="11.5" y="8" width="3" height="5" rx="1"/>`,
  "chart-pie": `<path d="M8 8L8 2A6 6 0 0 1 11.53 12.85Z"/><path d="M8 8L11.53 12.85A6 6 0 0 1 2 8Z" opacity="0.65"/><path d="M8 8L2 8A6 6 0 0 1 8 2Z" opacity="0.4"/>`,
  "heart-pulse": `<path d="M8 12.5c-3.5-2.5-6.5-5-6.5-8a3.5 3.5 0 0 1 6.5-2 3.5 3.5 0 0 1 6.5 2c0 3-3 5.5-6.5 8z"/>`,
  "dumbbell": `<rect x="1" y="5.5" width="3.5" height="5" rx="1"/><rect x="11.5" y="5.5" width="3.5" height="5" rx="1"/><rect x="4" y="7.25" width="8" height="1.5" rx="0.75"/>`,
};

const features = [
  {
    title: "Science-Backed Formulas",
    desc: "All calculators use peer-reviewed equations including Mifflin-St Jeor and Katch-McArdle, the gold standards in sports nutrition.",
    icon: "beaker",
  },
  {
    title: "Completely Free",
    desc: "No account required, no paywalls, no upsells. Just accurate, instant results whenever you need them.",
    icon: "gift",
  },
  {
    title: "Privacy First",
    desc: "Your measurements stay on your device. We never store personal health data on our servers.",
    icon: "shield",
  },
];
---

<Layout
  title="Free Nutrition Calculators — TDEE, Macros, BMR & More | CaloricLab"
  description="Science-backed nutrition calculators: TDEE, calorie deficit, macros, BMR, and protein. Free, accurate, and no signup required."
>
  <slot name="head" slot="head">
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "CaloricLab",
        "url": "https://caloriclab.com",
        "description": "Free, science-backed nutrition calculators",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://caloriclab.com/blog/?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      })}
    </script>
  </slot>

  <!-- Hero -->
  <section class="bg-[#F9FFFF] pt-16 pb-20 sm:pt-20 sm:pb-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">

        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-green-50 border border-green-100 text-green-700 text-xs font-semibold uppercase tracking-wider mb-7">
          <svg class="w-3 h-3" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm.75 3.75a.75.75 0 0 0-1.5 0v3.5H3.75a.75.75 0 0 0 0 1.5h3.5v3.5a.75.75 0 0 0 1.5 0v-3.5h3.5a.75.75 0 0 0 0-1.5h-3.5v-3.5z"/>
          </svg>
          Science-Backed Calculations
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 tracking-tight">
          Know Your Numbers.<br />
          <span class="text-green-600">Hit Your Goals.</span>
        </h1>

        <p class="mt-6 text-lg sm:text-xl text-gray-500 leading-relaxed max-w-2xl mx-auto">
          Free, precision nutrition calculators built on peer-reviewed science.
          Get your TDEE, macros, calorie targets, and more — in seconds.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href="/tdee-calculator/"
            class="btn-primary w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3.5 text-sm font-semibold rounded-xl shadow-sm"
          >
            Calculate Your TDEE
            <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.44 8 8.22 4.78a.75.75 0 0 1 0-1.06z" clip-rule="evenodd"/>
              <path fill-rule="evenodd" d="M2.75 8a.75.75 0 0 1 .75-.75h8a.75.75 0 0 1 0 1.5h-8A.75.75 0 0 1 2.75 8z" clip-rule="evenodd"/>
            </svg>
          </a>
          <a
            href="/macro-calculator/"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-white hover:bg-green-50 text-green-700 text-sm font-semibold rounded-xl border border-green-200 hover:border-green-300 transition-colors"
          >
            Get My Macros
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="mt-10 flex flex-wrap items-center justify-center gap-5">
          {[
            "No account required",
            "100% free forever",
            "Mifflin-St Jeor formula",
            "Privacy friendly",
          ].map(label => (
            <span class="flex items-center gap-1.5 text-xs text-gray-400 font-medium">
              <svg class="w-3.5 h-3.5 text-green-600 flex-shrink-0" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M12.416 3.376a.75.75 0 0 1 .208 1.04l-5 7.5a.75.75 0 0 1-1.154.114l-3-3a.75.75 0 0 1 1.06-1.06l2.353 2.353 4.493-6.74a.75.75 0 0 1 1.04-.207z" clip-rule="evenodd"/>
              </svg>
              {label}
            </span>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- Calculator cards -->
  <section class="bg-white py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">All Calculators</h2>
        <p class="mt-3 text-gray-500 max-w-xl mx-auto">Choose the calculator that matches your goal. They all work together — start with TDEE and build from there.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5">
        {calculators.map((calc, i) => (
          <a
            href={calc.href}
            class:list={[
              "group relative bg-white rounded-2xl border border-gray-200 p-6 shadow-sm hover:bg-[#F9FFFF] hover:border-green-300 hover:shadow-xl hover:shadow-green-900/10 hover:-translate-y-0.5 transition-all duration-200",
              i === 0 ? "lg:col-span-1 ring-1 ring-teal-200/60" : "",
            ]}
          >
            {calc.tag && (
              <span class="absolute top-4 right-4 text-xs font-semibold text-green-700 bg-green-50 px-2.5 py-1 rounded-full">
                {calc.tag}
              </span>
            )}
            <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center mb-4 group-hover:bg-green-100 transition-colors">
              <svg class="w-5 h-5 text-green-700" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" set:html={calcIcons[calc.icon] ?? calcIcons["flame"]}/>
            </div>
            <h3 class="text-base font-semibold text-gray-900 group-hover:text-green-700 transition-colors">{calc.name}</h3>
            <p class="mt-2 text-sm text-gray-500 leading-relaxed">{calc.desc}</p>
            <div class="mt-4 flex items-center gap-1 text-xs font-semibold text-green-700 opacity-0 group-hover:opacity-100 transition-opacity">
              Use calculator
              <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.44 8 8.22 4.78a.75.75 0 0 1 0-1.06z" clip-rule="evenodd"/>
                <path fill-rule="evenodd" d="M2.75 8a.75.75 0 0 1 .75-.75h8a.75.75 0 0 1 0 1.5h-8A.75.75 0 0 1 2.75 8z" clip-rule="evenodd"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why CaloricLab -->
  <section class="bg-[#F9FFFF] py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Why CaloricLab?</h2>
        <p class="mt-3 text-gray-500 max-w-xl mx-auto">Built for people who want real answers, not guesswork.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {features.map(f => (
          <div class="text-center">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-green-50 mb-5">
              <svg class="w-6 h-6 text-green-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                {f.icon === "beaker" && <><path d="M9 3H15"/><path d="M10 3v4.5L5.5 14A2 2 0 0 0 7.11 17H16.89A2 2 0 0 0 18.5 14L14 7.5V3"/></>}
                {f.icon === "gift" && <><path d="M20 12v10H4V12"/><path d="M2 7h20v5H2z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></>}
                {f.icon === "shield" && <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></>}
              </svg>
            </div>
            <h3 class="text-base font-semibold text-gray-900 mb-2">{f.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Articles -->
  <section class="bg-white py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">From the Blog</h2>
          <p class="mt-2 text-gray-500">Evidence-based nutrition guides to help you get results.</p>
        </div>
        <a href="/blog/" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold text-green-700 hover:text-green-800 transition-colors">
          All articles
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.44 8 8.22 4.78a.75.75 0 0 1 0-1.06z" clip-rule="evenodd"/>
            <path fill-rule="evenodd" d="M2.75 8a.75.75 0 0 1 .75-.75h8a.75.75 0 0 1 0 1.5h-8A.75.75 0 0 1 2.75 8z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {recentPosts.map(post => (
          <a
            href={`/blog/${post.id.replace(/\.md$/, '')}/`}
            class="group bg-white rounded-2xl border border-gray-200 overflow-hidden hover:bg-[#F9FFFF] hover:border-green-200 hover:shadow-lg hover:shadow-green-900/5 hover:-translate-y-0.5 transition-all duration-200"
          >
            {post.data.heroImage ? (
              <div class="aspect-video overflow-hidden bg-gray-100">
                <img
                  src={post.data.heroImage}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="aspect-video bg-gradient-to-br from-green-50 to-teal-50 flex items-center justify-center">
                <svg class="w-10 h-10 text-green-200" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/>
                </svg>
              </div>
            )}
            <div class="p-5">
              {post.data.tags.length > 0 && (
                <span class="inline-block text-xs font-semibold text-green-700 bg-green-50 px-2.5 py-0.5 rounded-full mb-3">
                  {post.data.tags[0]}
                </span>
              )}
              <h3 class="text-sm font-semibold text-gray-900 leading-snug group-hover:text-green-700 transition-colors line-clamp-2">
                {post.data.title}
              </h3>
              <p class="mt-2 text-xs text-gray-500 leading-relaxed line-clamp-2">{post.data.description}</p>
              <p class="mt-3 text-xs text-gray-400">
                <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              </p>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-8 sm:hidden text-center">
        <a href="/blog/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-green-700 hover:text-green-800 transition-colors">
          View all articles
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.44 8 8.22 4.78a.75.75 0 0 1 0-1.06z" clip-rule="evenodd"/>
            <path fill-rule="evenodd" d="M2.75 8a.75.75 0 0 1 .75-.75h8a.75.75 0 0 1 0 1.5h-8A.75.75 0 0 1 2.75 8z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-[#F9FFFF] py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
        Ready to get started?
      </h2>
      <p class="mt-3 text-gray-500 text-base">
        Pick a calculator and get your numbers in under two minutes.
      </p>
      <div class="mt-7 flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/tdee-calculator/"
          class="btn-primary inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold rounded-xl shadow-sm"
        >
          Calculate Your TDEE
        </a>
        <a
          href="/bmr-calculator/"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white hover:bg-green-50 text-green-700 text-sm font-semibold rounded-xl border border-green-200 hover:border-green-300 transition-colors"
        >
          BMR Calculator
        </a>
      </div>
    </div>
  </section>
</Layout>
