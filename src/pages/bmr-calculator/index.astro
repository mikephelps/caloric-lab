---
import CalculatorLayout from "../../layouts/CalculatorLayout.astro";
import BMRCalculator from "../../components/BMRCalculator";

const relatedCalcs = [
  { name: "TDEE Calculator", href: "/tdee-calculator/", desc: "Add activity to get your full daily burn" },
  { name: "Calorie Deficit Calculator", href: "/calorie-deficit-calculator/", desc: "Set a calorie deficit for fat loss" },
  { name: "Macro Calculator", href: "/macro-calculator/", desc: "Break your calories into macros" },
];

const faqSchema = [
  {
    question: "What is BMR?",
    answer: "BMR (Basal Metabolic Rate) is the number of calories your body needs to perform basic life-sustaining functions at complete rest: breathing, circulation, cell production, and organ function.",
  },
  {
    question: "What's the difference between BMR and TDEE?",
    answer: "BMR is your resting calorie burn only. TDEE (Total Daily Energy Expenditure) is BMR multiplied by an activity factor to account for movement and exercise.",
  },
  {
    question: "Which BMR formula is most accurate?",
    answer: "The Mifflin-St Jeor equation is considered the most accurate for most people. The Katch-McArdle formula is more accurate if you know your body fat percentage, as it accounts for lean mass directly.",
  },
];
---

<CalculatorLayout
  title="BMR Calculator: Free and Accurate"
  pageTitle="BMR Calculator"
  description="Calculate your BMR using the Mifflin-St Jeor equation. Free, instant results with no email required. Science-backed, accurate, and mobile-friendly."
  subtitle="Your BMR is the minimum calories your body needs to survive. It's the starting point for calculating your full daily calorie needs."
  breadcrumb="BMR Calculator"
  {relatedCalcs}
  {faqSchema}
>
  <BMRCalculator client:load slot="calculator" />

  <div slot="content">
    <div class="prose prose-gray max-w-none">
      <h2 class="text-xl font-bold text-gray-900 mb-4">What Is Basal Metabolic Rate?</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Your <strong>Basal Metabolic Rate (BMR)</strong> represents the energy your body expends at complete rest
        to maintain essential physiological functions. This includes maintaining body temperature, circulating
        blood, breathing, and keeping every cell in your body alive.
      </p>
      <p class="text-gray-600 leading-relaxed mb-6">
        BMR typically accounts for <strong>60–75% of your total daily calorie burn</strong>, making it the
        most important factor in your overall energy equation.
      </p>

      <h2 class="text-xl font-bold text-gray-900 mb-4">BMR Formulas</h2>
      <div class="space-y-4 mb-6">
        <div class="bg-[#F9FFFF] rounded-xl border border-green-100 p-5">
          <p class="text-sm font-semibold text-gray-700 mb-2">Mifflin-St Jeor (Default)</p>
          <p class="font-mono text-xs text-gray-600"><span class="font-bold">Male:</span> (10 × kg) + (6.25 × cm) − (5 × age) + 5</p>
          <p class="font-mono text-xs text-gray-600 mt-1"><span class="font-bold">Female:</span> (10 × kg) + (6.25 × cm) − (5 × age) − 161</p>
        </div>
        <div class="bg-[#F9FFFF] rounded-xl border border-green-100 p-5">
          <p class="text-sm font-semibold text-gray-700 mb-2">Katch-McArdle (If you know body fat %)</p>
          <p class="font-mono text-xs text-gray-600">BMR = 370 + (21.6 × lean mass in kg)</p>
          <p class="text-xs text-gray-500 mt-1">More accurate if you have a body composition measurement.</p>
        </div>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
      <div class="space-y-5">
        {faqSchema.map(faq => (
          <div>
            <h3 class="font-semibold text-gray-900 mb-1.5">{faq.question}</h3>
            <p class="text-gray-600 leading-relaxed text-sm">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</CalculatorLayout>
