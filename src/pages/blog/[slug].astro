---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import GlassHero from "../../components/GlassHero.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}

const siteUrl = "https://caloriclab.com";
const postUrl = `${siteUrl}/blog/${post.id.replace(/\.md$/, "")}/`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "author": { "@type": "Person", "name": post.data.author },
  "datePublished": post.data.pubDate.toISOString(),
  "url": postUrl,
  "publisher": {
    "@type": "Organization",
    "name": "CaloricLab",
    "url": siteUrl,
  },
};
---

<Layout
  title={post.data.title}
  description={post.data.description}
  canonicalUrl={postUrl}
  ogType="article"
  ogImage={post.data.heroImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <!-- Article header — liquid glass -->
  <GlassHero title={post.data.title} subtitle={post.data.description}>
    <div slot="above">
      <nav class="flex items-center gap-2 mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-xs text-white/50 hover:text-white/80 transition-colors">Home</a>
        <svg class="w-3 h-3 text-white/25" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06L7.28 11.78a.75.75 0 0 1-1.06-1.06L8.94 8 6.22 5.28a.75.75 0 0 1 0-1.06z" clip-rule="evenodd"/>
        </svg>
        <a href="/blog/" class="text-xs text-white/50 hover:text-white/80 transition-colors">Blog</a>
        <svg class="w-3 h-3 text-white/25" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06L7.28 11.78a.75.75 0 0 1-1.06-1.06L8.94 8 6.22 5.28a.75.75 0 0 1 0-1.06z" clip-rule="evenodd"/>
        </svg>
        <span class="text-xs text-white/75 font-medium truncate max-w-[12rem]">{post.data.title}</span>
      </nav>
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {post.data.tags.map(tag => (
            <span class="text-xs font-semibold text-green-300 bg-white/[0.08] backdrop-blur-sm px-2.5 py-1 rounded-full border border-white/[0.12]">{tag}</span>
          ))}
        </div>
      )}
    </div>
    <div slot="below" class="mt-5 flex items-center gap-3 text-sm text-white/45">
      <span>{post.data.author}</span>
      <span class="text-white/20">·</span>
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    </div>
  </GlassHero>

  {post.data.heroImage && (
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
      <img
        src={post.data.heroImage}
        alt={post.data.title}
        class="w-full rounded-2xl aspect-video object-cover"
      />
    </div>
  )}

  <!-- Article content -->
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="prose prose-gray prose-lg max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-a:text-green-700 prose-a:no-underline hover:prose-a:underline">
      <Content />
    </div>

    <!-- Back to blog -->
    <div class="mt-12 pt-8 border-t border-gray-100">
      <a href="/blog/" class="inline-flex items-center gap-2 text-sm font-semibold text-green-700 hover:text-green-800 transition-colors">
        <svg class="w-4 h-4 rotate-180" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.44 8 8.22 4.78a.75.75 0 0 1 0-1.06z" clip-rule="evenodd"/>
          <path fill-rule="evenodd" d="M2.75 8a.75.75 0 0 1 .75-.75h8a.75.75 0 0 1 0 1.5h-8A.75.75 0 0 1 2.75 8z" clip-rule="evenodd"/>
        </svg>
        Back to Blog
      </a>
    </div>
  </article>
</Layout>
