---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import GlassHero from "../../components/GlassHero.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}
---

<Layout
  title="Nutrition & Health Blog"
  description="Evidence-based articles on nutrition, calorie counting, macros, fat loss, and muscle building. Written by the CaloricLab team."
>
  <!-- Page header — liquid glass -->
  <GlassHero
    title="Blog"
    subtitle="Evidence-based nutrition and fitness insights to help you make smarter decisions about your health."
  />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    {posts.length === 0 ? (
      <div class="text-center py-20">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-green-50 mb-5">
          <svg class="w-7 h-7 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/>
          </svg>
        </div>
        <h2 class="text-xl font-bold text-gray-900 mb-2">Articles coming soon</h2>
        <p class="text-gray-500 text-sm max-w-sm mx-auto">We're working on science-backed articles on nutrition, fat loss, muscle building, and more.</p>
        <a href="/tdee-calculator/" class="mt-6 inline-flex items-center gap-2 px-5 py-2.5 bg-green-700 hover:bg-green-800 text-white text-sm font-semibold rounded-xl transition-colors">
          Try our calculators
        </a>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <a
            href={`/blog/${post.id.replace(/\.md$/, '')}/`}
            class="group bg-white rounded-2xl border border-gray-100 overflow-hidden hover:border-green-200 hover:shadow-lg hover:shadow-green-50 transition-all duration-200"
          >
            {post.data.heroImage && (
              <div class="aspect-video bg-gray-100 overflow-hidden">
                <img
                  src={post.data.heroImage}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-5">
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mb-3">
                  {post.data.tags.slice(0, 2).map(tag => (
                    <span class="text-xs font-medium text-green-700 bg-green-50 px-2 py-0.5 rounded-full">{tag}</span>
                  ))}
                </div>
              )}
              <h2 class="text-base font-bold text-gray-900 group-hover:text-green-700 transition-colors leading-snug">{post.data.title}</h2>
              <p class="mt-2 text-sm text-gray-500 leading-relaxed line-clamp-2">{post.data.description}</p>
              <div class="mt-4 flex items-center justify-between">
                <span class="text-xs text-gray-400">{formatDate(post.data.pubDate)}</span>
                <span class="text-xs font-semibold text-green-700">Read more →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>
