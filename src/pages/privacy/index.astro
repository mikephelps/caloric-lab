---
import Layout from "../../layouts/Layout.astro";
import GlassHero from "../../components/GlassHero.astro";
const updated = "April 20, 2026";
---

<Layout
  title="Privacy Policy"
  description="CaloricLab privacy policy. Learn how we handle (and don't collect) your personal health data."
  noindex={false}
>
  <!-- Page header — liquid glass -->
  <GlassHero title="Privacy Policy">
    <p slot="below" class="mt-2 text-xs text-white/40">Last updated: {updated}</p>
  </GlassHero>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14 space-y-8">

    <!-- TL;DR highlights -->
    <div class="bg-green-50 border border-green-100 rounded-2xl p-5">
      <p class="text-xs font-semibold text-green-700 uppercase tracking-wider mb-3">Privacy at a glance</p>
      <ul class="space-y-2">
        {[
          "Your health data (weight, height, age) never leaves your browser. We can't see it.",
          "We collect anonymous analytics only: page views and browser type.",
          "Advertising partners may use cookies for ad targeting. You can opt out.",
        ].map(point => (
          <li class="flex items-start gap-2.5 text-sm text-gray-700">
            <svg class="w-4 h-4 text-green-600 flex-shrink-0 mt-0.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M12.416 3.376a.75.75 0 0 1 .208 1.04l-5 7.5a.75.75 0 0 1-1.154.114l-3-3a.75.75 0 0 1 1.06-1.06l2.353 2.353 4.493-6.74a.75.75 0 0 1 1.04-.207z" clip-rule="evenodd"/>
            </svg>
            {point}
          </li>
        ))}
      </ul>
    </div>

    <!-- Intro -->
    <p class="text-gray-600 leading-relaxed">
      At CaloricLab ("we," "us," or "our"), your privacy is important to us. This policy explains
      what information we collect, how we use it, and how we protect it.
    </p>

    <!-- Sections -->
    <div class="space-y-7">

      <div>
        <h2 class="text-base font-bold text-gray-900 mb-2">Information We Do Not Collect</h2>
        <p class="text-gray-600 leading-relaxed text-sm">
          All calculations on CaloricLab are performed <strong class="text-gray-800">entirely in your browser</strong>.
          When you enter your age, weight, height, or other personal measurements into our calculators,
          that data is never sent to our servers. We have no access to your health data.
        </p>
      </div>

      <hr class="border-gray-100"/>

      <div>
        <h2 class="text-base font-bold text-gray-900 mb-2">Information We Collect Automatically</h2>
        <p class="text-gray-600 leading-relaxed text-sm mb-3">
          Like most websites, we collect standard analytics data when you visit CaloricLab, including:
        </p>
        <ul class="space-y-1.5">
          {[
            "Pages visited and time spent on pages",
            "Referring URLs (how you found us)",
            "Browser type and operating system",
            "Approximate geographic location (country/region level only)",
          ].map(item => (
            <li class="flex items-center gap-2 text-sm text-gray-600">
              <span class="w-1.5 h-1.5 rounded-full bg-gray-300 flex-shrink-0"/>
              {item}
            </li>
          ))}
        </ul>
        <p class="mt-3 text-gray-500 text-sm leading-relaxed">
          This information is collected in aggregate and cannot be used to identify you personally.
        </p>
      </div>

      <hr class="border-gray-100"/>

      <div>
        <h2 class="text-base font-bold text-gray-900 mb-2">Advertising</h2>
        <p class="text-gray-600 leading-relaxed text-sm">
          CaloricLab is supported by display advertising. Our advertising partners may use cookies
          to show you relevant ads. You can opt out of personalized advertising through your browser
          settings or through the Network Advertising Initiative opt-out page.
        </p>
      </div>

      <hr class="border-gray-100"/>

      <div>
        <h2 class="text-base font-bold text-gray-900 mb-2">Cookies</h2>
        <p class="text-gray-600 leading-relaxed text-sm">
          We use cookies for analytics and advertising purposes. Essential cookies are required for
          the site to function. You can disable non-essential cookies in your browser settings,
          though this may affect your experience.
        </p>
      </div>

      <hr class="border-gray-100"/>

      <div>
        <h2 class="text-base font-bold text-gray-900 mb-2">Third-Party Services</h2>
        <p class="text-gray-600 leading-relaxed text-sm">
          We use third-party services including analytics and advertising platforms. These services
          have their own privacy policies governing how they handle data.
        </p>
      </div>

      <hr class="border-gray-100"/>

      <div>
        <h2 class="text-base font-bold text-gray-900 mb-2">Children's Privacy</h2>
        <p class="text-gray-600 leading-relaxed text-sm">
          CaloricLab is not directed at children under 13. We do not knowingly collect personal
          information from children.
        </p>
      </div>

      <hr class="border-gray-100"/>

      <div>
        <h2 class="text-base font-bold text-gray-900 mb-2">Changes to This Policy</h2>
        <p class="text-gray-600 leading-relaxed text-sm">
          We may update this privacy policy from time to time. We'll note the last updated date
          at the top of this page.
        </p>
      </div>

      <hr class="border-gray-100"/>

      <div>
        <h2 class="text-base font-bold text-gray-900 mb-2">Contact</h2>
        <p class="text-gray-600 leading-relaxed text-sm">
          Questions about this policy? Email us at{" "}
          <a href="mailto:mikeephelps@gmail.com" class="text-green-700 font-medium hover:underline">mikeephelps@gmail.com</a>.
        </p>
      </div>

    </div>
  </div>
</Layout>
