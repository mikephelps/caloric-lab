---
import Layout from "./Layout.astro";
import GlassHero from "../components/GlassHero.astro";

interface RelatedCalc {
  name: string;
  href: string;
  desc: string;
}

interface Props {
  title: string;
  pageTitle: string;
  description: string;
  subtitle: string;
  relatedCalcs: RelatedCalc[];
  breadcrumb: string;
  canonicalUrl?: string;
  faqSchema?: Array<{ question: string; answer: string }>;
}

const {
  title,
  pageTitle,
  description,
  subtitle,
  relatedCalcs,
  breadcrumb,
  canonicalUrl,
  faqSchema,
} = Astro.props;

const siteUrl = "https://caloriclab.com";
const canonical = canonicalUrl ?? siteUrl + Astro.url.pathname;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": breadcrumb, "item": canonical },
  ],
};

const faqJsonLd = faqSchema ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqSchema.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer },
  })),
} : null;
---

<Layout {title} {description} {canonicalUrl}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    )}
  </Fragment>

  <!-- Page header — liquid glass -->
  <GlassHero title={pageTitle} subtitle={subtitle}>
    <nav slot="above" class="flex items-center gap-2 mb-5" aria-label="Breadcrumb">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-xs text-white/50 hover:text-white/80 transition-colors"
      >Home</a>
      <svg class="w-3 h-3 text-white/25" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06L7.28 11.78a.75.75 0 0 1-1.06-1.06L8.94 8 6.22 5.28a.75.75 0 0 1 0-1.06z" clip-rule="evenodd"/>
      </svg>
      <span class="text-xs text-white/75 font-medium">{breadcrumb}</span>
    </nav>
  </GlassHero>

  <!-- Calculator + content area -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">

      <!-- Calculator column -->
      <div class="lg:col-span-2">
        <!-- React calculator island will go here -->
        <slot name="calculator">
          <div class="bg-white rounded-2xl border border-gray-200 p-8 text-center text-gray-400 min-h-64 flex items-center justify-center">
            <div>
              <svg class="w-8 h-8 mx-auto mb-3 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/>
              </svg>
              <p class="text-sm">Calculator coming soon</p>
            </div>
          </div>
        </slot>

        <!-- SEO content -->
        <div class="mt-10">
          <slot name="content" />
        </div>
      </div>

      <!-- Sidebar — sticky on desktop -->
      <div class="space-y-6 lg:sticky lg:top-24 lg:self-start">
        <!-- Related calculators -->
        <div class="bg-gray-50 rounded-2xl border border-gray-100 p-5">
          <h3 class="text-sm font-semibold text-gray-900 mb-4">Related Calculators</h3>
          <div class="space-y-2">
            {relatedCalcs.map(c => (
              <a
                href={c.href}
                class="group flex items-start gap-3 p-3 rounded-xl hover:bg-white hover:shadow-sm transition-all"
              >
                <div class="mt-0.5 flex-shrink-0 w-7 h-7 rounded-lg bg-green-100 flex items-center justify-center">
                  <svg class="w-3.5 h-3.5 text-green-700" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                    <path d="M2 3a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3zm0 6a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V9zm8 0a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1V9zm0 4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-1z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-sm font-medium text-gray-800 group-hover:text-green-700 transition-colors">{c.name}</div>
                  <div class="text-xs text-gray-500 mt-0.5 leading-relaxed">{c.desc}</div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Disclaimer -->
        <div class="bg-amber-50 rounded-2xl border border-amber-100 p-5">
          <p class="text-xs text-amber-700 leading-relaxed">
            <span class="font-semibold">Disclaimer:</span> Results are estimates based on population averages and established equations. Individual results may vary. Always consult a registered dietitian or healthcare professional before making significant dietary changes.
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
